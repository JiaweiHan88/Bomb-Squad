{
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "typecheck": "pnpm -r exec tsc --noEmit",
    "build": "pnpm -r build",

# Bomb Squad reverse proxy.
# Local dev uses "tls internal" (Caddy generates a local CA cert).
# Production: replace ":443" block header with your domain (e.g. "bombsquad.example.com")
# and remove "tls internal" — Caddy will obtain a Let's Encrypt cert automatically.

{
  # Caddy admin API on 2019 (HTTP only) — used by the in-container health check.
  # Bound to localhost so other containers on the compose network can't reach
  # the (unauthenticated) admin API and reconfigure the proxy.
  admin localhost:2019
}

# Redirect HTTP → HTTPS
:80 {
  redir https://{host}{uri} permanent
}

:443 {
  tls internal

  # ── Socket.IO — Caddy handles the WebSocket upgrade natively ────────────────
  @socketio {
    path /socket.io/*
  }
  reverse_proxy @socketio server:{$PORT:3001}

  # ── Health endpoint (for external probes through TLS) ───────────────────────
  reverse_proxy /health server:{$PORT:3001}

  # ── Client SPA (everything else) ────────────────────────────────────────────
  reverse_proxy /* client:5173
}

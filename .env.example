# Copy this file to .env and fill in real values — never commit .env

# LiveKit
LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY must not contain ':' — it is joined into LIVEKIT_KEYS as
# "key: secret" and a colon in the key breaks LiveKit's parsing.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL
# POSTGRES_PASSWORD is the single source of truth in-compose: it sets the
# postgres container's password AND the server's DATABASE_URL override.
# The DATABASE_URL below is for host-run dev only; keep its password in sync.
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bombsquad

# coturn TURN
# TURN_SECRET must not contain whitespace or quotes — it is passed to coturn
# as a CLI argument. It also signs the short-TTL TURN-REST credentials the
# server mints into the VOICE_TOKEN grant (Story 3.6), so the server and coturn
# MUST share the same value.
TURN_SECRET=changeme
TURN_TTL=86400
# Optional (Story 3.6): browser-reachable TURN URI handed to the client in the
# VOICE_TOKEN grant for the corporate-NAT relay path. Like LIVEKIT_URL, its host
# must be reachable FROM THE BROWSER (a compose service name is unresolvable in a
# browser). Leave unset to disable explicit TURN (client uses LiveKit's own ICE).
# Localhost dev: turn:localhost:3478
# TURN_URL=turn:localhost:3478
# Advertised coturn relay address (--external-ip). Set to the host's PUBLIC IP in
# production. Unset ⇒ defaults to 127.0.0.1 (correct for the published-port
# localhost dev stack). For the forced-relay verification on WSL2 keep 127.0.0.1.
# TURN_EXTERNAL_IP=

# Server
PORT=3001
